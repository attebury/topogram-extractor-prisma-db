datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

model User {
  id    String @id
  email String @unique
  name  String?
  role  Role   @default(USER)
  posts Post[]

  @@index([role])
}

model Post {
  id        String  @id
  title     String
  published Boolean @default(false)
  authorId  String
  author    User    @relation(fields: [authorId], references: [id])

  @@index([authorId])
}
